---
import BaseLayout from "../layouts/BaseLayout.astro";
import { collectTags, entryCoverImage, entryDefaultCoverImage, entryLocation, entrySlug, formatDate, getPublishedEntries, typeLabels } from "../lib/entries";
import { getLatestXPosts } from "../lib/x-posts";

const entries = await getPublishedEntries();
const tags = collectTags(entries).slice(0, 14);
const xPosts = await getLatestXPosts(5);
const visibleEntryLimit = 8;
const hasMoreEntries = entries.length > visibleEntryLimit;

function formatXDate(date?: string) {
  if (!date) return "X";
  const parsed = new Date(date);
  if (Number.isNaN(parsed.valueOf())) return "X";
  return new Intl.DateTimeFormat("zh-CN", {
    month: "short",
    day: "numeric"
  }).format(parsed);
}
---

<BaseLayout>
  <main>
    <section class="hero">
      <div class="hero-copy">
        <h1>東嬉遊記</h1>
        <p class="lede">把一次温泉、一段车程、一间酒店和一座城市，慢慢写成可以回望、检索、继续生长的旅行笔记。</p>
      </div>
      <aside class={xPosts.length > 0 ? "x-panel has-posts" : "x-panel"} aria-label="X">
        <a class="x-link" href="https://x.com/don_tsua" target="_blank" rel="noopener noreferrer" aria-label="打开 @don_tsua 的 X 主页">
          <span class="x-logo-mark" aria-hidden="true">
            <img src="/images/x-logo.svg" alt="" width="20" height="20" />
          </span>
          <span class="x-profile-copy">
            <span class="x-eyebrow">@don_tsua</span>
            {xPosts.length === 0 && <small>新的行程、照片和临时想法，会先落在这里。</small>}
          </span>
        </a>
        {xPosts.length > 0 && (
          <div class="x-posts">
            {xPosts.map((post) => (
              <a class="x-post" href={post.url} target="_blank" rel="noopener noreferrer">
                <img class="x-post-avatar" src="/images/dongxi-avatar.jpg" alt="" width="40" height="40" />
                <span class="x-post-content">
                  <span class="x-post-meta">
                    <strong>東嬉遊記</strong>
                    <span>@don_tsua</span>
                    <span>·</span>
                    <time datetime={post.createdAt}>{formatXDate(post.createdAt)}</time>
                  </span>
                <p>{post.text}</p>
                </span>
              </a>
            ))}
          </div>
        )}
      </aside>
    </section>

    <section id="records" class="content-band">
      <div class="section-heading">
        <h2>全部记录</h2>
      </div>
      <div class="entry-grid">
        {entries.map((entry, index) => (
          <article class={index >= visibleEntryLimit ? "entry-card is-extra" : "entry-card"} data-extra={index >= visibleEntryLimit ? "true" : undefined} hidden={index >= visibleEntryLimit}>
            <a href={`/entries/${entrySlug(entry)}`}>
              <span class="entry-cover">
                <img src={entryCoverImage(entry, index)} data-fallback-src={entryDefaultCoverImage(index)} alt="" loading="lazy" />
              </span>
              <span class="entry-meta">{typeLabels[entry.data.type]} · {formatDate(entry.data.date)}</span>
              <h3>{entry.data.title}</h3>
              <p>{entry.data.summary}</p>
              <span class="entry-place">{entryLocation(entry) || entry.data.country}</span>
            </a>
          </article>
        ))}
      </div>
      {hasMoreEntries && (
        <div class="more-row">
          <button class="more-button" type="button" data-show-more>更多</button>
        </div>
      )}
    </section>

    <section class="content-band compact">
      <div class="section-heading">
        <p class="kicker">AI tags</p>
        <h2>语义标签</h2>
      </div>
      <div class="tag-cloud">
        {tags.map(({ tag, count }) => (
          <a href={`/tags/${encodeURIComponent(tag)}`}>{tag}<span>{count}</span></a>
        ))}
      </div>
    </section>
  </main>
  <script is:inline>
    const showMoreButton = document.querySelector("[data-show-more]");
    showMoreButton?.addEventListener("click", () => {
      document.querySelectorAll('[data-extra="true"]').forEach((entry) => {
        entry.hidden = false;
      });
      showMoreButton.hidden = true;
    });
  </script>
</BaseLayout>
