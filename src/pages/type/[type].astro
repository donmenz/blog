---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { entryCoverImage, entryDefaultCoverImage, entryLocation, entrySlug, formatDate, getPublishedEntries, typeLabels } from "../../lib/entries";

export async function getStaticPaths() {
  return Object.keys(typeLabels).map((type) => ({ params: { type } }));
}

const { type } = Astro.params;
const label = typeLabels[type] ?? type;
const entries = (await getPublishedEntries()).filter((entry) => {
  return entry.data.type === type || entry.data.topics.includes(label) || entry.data.topics.includes(type);
});
---

<BaseLayout title={label} description={`東嬉遊記的${label}记录。`}>
  <main class="listing-shell">
    <header class="listing-header">
      <p class="kicker">Type index</p>
      <h1>{label}</h1>
      <p>{entries.length} 篇结构化记录</p>
    </header>
    <div class="entry-grid">
      {entries.map((entry, index) => (
        <article class="entry-card">
          <a href={`/entries/${entrySlug(entry)}`}>
            <span class="entry-cover">
              <img src={entryCoverImage(entry, index)} data-fallback-src={entryDefaultCoverImage(index)} alt="" loading="lazy" />
            </span>
            <span class="entry-meta">{formatDate(entry.data.date)}</span>
            <h2>{entry.data.title}</h2>
            <p>{entry.data.summary}</p>
            <span class="entry-place">{entryLocation(entry) || entry.data.country}</span>
          </a>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
